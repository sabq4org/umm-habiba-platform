# ====================================================================
# منصة أم حبيبة التعليمية - متغيرات البيئة
# انسخي هذا الملف إلى .env.local للتطوير المحلي،
# واضبطي نفس القيم في إعدادات النشر (DigitalOcean / Vercel).
# ====================================================================

# قاعدة البيانات (Neon أو أي PostgreSQL)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# سرّ توقيع جلسات تسجيل الدخول (HMAC-SHA256)
# أنشئي قيمة عشوائية طويلة: openssl rand -hex 48
AUTH_SECRET=replace-with-long-random-string-min-48-bytes

# ----- اختياري -----

# Origins إضافية مسموح بها لطلبات تسجيل الدخول، مفصولة بفواصل
# مثال: https://app.ummhabiba.example,https://admin.ummhabiba.example
# AUTH_ALLOWED_ORIGINS=

# اسمحي بالطلبات بدون Origin/Referer (غير موصى به)
# AUTH_ALLOW_MISSING_ORIGIN=0

# Node.js environment - تضبطه منصة الاستضافة عادةً
# NODE_ENV=production
